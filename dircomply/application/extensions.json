{
    "content_extensions": [
        ".txt", ".py", ".bat", ".html", ".ts",".json",".scss",".tcl",".md",
        ".yaml",".yml",".ini",".in",".sh",".gitignore"
    ],
    "existence_extensions": [
        ".xlsx", ".csv", ".docx",
        ".png",".jpeg",".jpg",".ods",
        ".pdf",".ico"
    ],
    "skip_dirs":[
        ".git", ".venv", "nodemodules", ".vscode", "__pycache__", "build"
    ]
}
